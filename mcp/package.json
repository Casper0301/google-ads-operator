{
  "name": "google-ads-mcp",
  "version": "1.0.0",
  "private": false,
  "description": "MCP server for Google Ads account operations. Pairs with google-ads-operator skill for safe plan-preview-confirm-execute write pipeline.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "mcp:dev": "tsx watch src/mcp/server.ts",
    "mcp:start": "node dist/mcp/server.js",
    "oauth:google": "tsx scripts/oauth-google.ts",
    "db:migrate": "supabase db push",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@supabase/supabase-js": "^2.45.0",
    "google-ads-api": "^23.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
