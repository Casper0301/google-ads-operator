# ─────────────────────────────────────────────────────────────────────────
# Supabase (create a project at supabase.com — free tier is plenty)
# ─────────────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_SCHEMA=public

# ─────────────────────────────────────────────────────────────────────────
# Token encryption (32-byte hex for AES-256-GCM)
# Generate with: openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────
GOOGLE_ADS_MCP_ENCRYPTION_KEY=

# ─────────────────────────────────────────────────────────────────────────
# Google Ads API credentials
# ─────────────────────────────────────────────────────────────────────────
# Apply at your MCC Admin → API Center for Basic access (1–3 day approval)
GOOGLE_ADS_DEVELOPER_TOKEN=

# OAuth 2.0 client credentials from Google Cloud console
# (console.cloud.google.com → APIs & Services → Credentials)
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=

# Your MCC (Manager Account) ID, digits only, no dashes
# Example: 1234567890 for MCC 123-456-7890
# Leave blank if you only manage a single non-MCC account.
GOOGLE_ADS_MCC_ID=

# OAuth redirect URI — default works for local development
GOOGLE_ADS_REDIRECT_URI=http://localhost:5432/oauth/google/callback
